<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <uses-permission android:name="android.permission.INTERNET" />

    <!-- Notificaciones en Android 13+ (API 33+) -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />

    <!-- WorkManager necesita este permiso para reagendarse tras reinicio -->
    <uses-permission android:name="android.permission.RECEIVE_BOOT_COMPLETED" />
    <uses-permission android:name="android.permission.CAMERA" />
    <uses-feature android:name="android.hardware.camera" android:required="false" />

    <application
        android:name=".NexoHogarApp"
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:label="NexoHogar"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.NexoHogar">

        <activity
            android:name=".presentation.MainActivity"
            android:exported="true"
            android:launchMode="singleTask">

            <intent-filter>
                <action android:name="android.intent.action.MAIN"/>
                <category android:name="android.intent.category.LAUNCHER"/>
            </intent-filter>

            <!-- Deep link para restablecer contraseña -->
            <intent-filter android:autoVerify="false">
                <action android:name="android.intent.action.VIEW"/>
                <category android:name="android.intent.category.DEFAULT"/>
                <category android:name="android.intent.category.BROWSABLE"/>
                <data
                    android:scheme="nexohogar"
                    android:host="reset-password"/>
            </intent-filter>

        </activity>

        <!--
            WorkManager registra su propio ContentProvider automáticamente.
            No es necesario declarar el Worker aquí — WorkManager lo descubre
            a través del classpath.
        -->
        <!-- Firebase Cloud Messaging -->
        <service
            android:name=".service.NexoHogarMessagingService"
            android:exported="false">
            <intent-filter>
                <action android:name="com.google.firebase.MESSAGING_EVENT" />
            </intent-filter>
        </service>

        ```


    </application>

</manifest>
